<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Blue gradient: lighter top → deeper bottom-right -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF1E88E5"/>
                <item android:offset="1.0" android:color="#FF0A3880"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle circular highlight (top-left) for depth -->
    <path
        android:fillColor="#16FFFFFF"
        android:pathData="M-20,-20 a84,84 0 0,1 84,84 L-20,84 Z"/>
</vector>
