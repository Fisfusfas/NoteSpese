rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Sviluppo: tutti gli utenti autenticati (Google + anonimo) possono leggere/scrivere.
    // TODO: applicare regole granulari prima della pubblicazione su Play Store.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
